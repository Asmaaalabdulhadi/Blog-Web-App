<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>

  <%- include("partials/header.ejs") %>

    <div class="px-4 py-5 my-5 text-center">
      <h1 class="display-5 fw-bold text-body-emphasis">Welcome to the Blog!</h1>
      <div class="col-lg-6 mx-auto">
        <p In this project ou can add new blog post, view them, update and delete a blog post. the data does not
          presists though as it is not linked to a database</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
          <button type="button" class="btn btn-outline-secondary btn-lg px-4"><a href="/createPost">New
              Post</a></button>
        </div>
      </div>
    </div>


    <div class="container">

      <h3>Latest Posts</h3>
      <% if(locals.PostCount>0){ console.log("post count",locals.PostCount );%>

        <% for (let i=0; i<PostCount; i++) { %>
          <h4>Article Name: <%=locals.PostContent[i].title %></h4>
          <h5>Published: <%=locals.PostContent[i].date %></h5>
          <h5>Author: <%=locals.PostContent[i].author %></h5>
          <h5>Post id:  <%=locals.PostContent[i].idp %> </h5>
          <button type="buttton"><a href="/editPost/currentID">Edit</a></button><button>Delete</button>
          <hr>
          <p><%=locals.PostContent[i].content %></p>
          <%} %>


            <% }else{%>
              <h2>No posts yet</h2>
              <% console.log(locals.PostContent); %>
                <% } %>

    </div>


  <%- include("partials/footer.ejs") %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>